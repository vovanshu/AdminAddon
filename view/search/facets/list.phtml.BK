<?php

$plugins = $this->getHelperPluginManager();
$AdminAddon = $this->AdminAddon();
$partial = $plugins->get('partial');
$escape = $plugins->get('escapeHtml');
$translate = $plugins->get('translate');
$escapeAttr = $plugins->get('escapeHtmlAttr');
$query = $this->params()->fromQuery();

$searchFasetsEnable = $AdminAddon->getSiteSets('search_fasets_enable');
$searchFasets = $AdminAddon->getSiteSets('search_fasets');
if(!empty($searchFasets)){
    $searchFasets = parse_ini_string($searchFasets, true, INI_SCANNER_TYPED);
}else{
    $searchFasets = [];
}

// $facets = [
